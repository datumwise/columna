---
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import AmbientChip from '../components/AmbientChip.astro';

export interface Props {
  title: string;
  description?: string;
  /** Home is a full-bleed argument scroll; inner pages use a centered reading column. */
  wide?: boolean;
}
const {
  title,
  description = 'datumwise builds and stewards Columna — an open-source data framework (Manifold, FrameQL, an honest engine) that refuses to return a confident wrong number.',
  wide = false,
} = Astro.props;

const nav = [
  { label: 'Learn', href: '/learn' },
  { label: 'The Case', href: '/case' },
  { label: 'The Thesis', href: '/thesis' },
  { label: 'Why', href: '/why' },
  { label: 'The Ladder', href: '/ladder' },
  { label: 'The Atlas', href: '/atlas' },
  { label: 'GitHub', href: 'https://github.com/datumwise/columna', external: true },
];
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a href="#main" class="skip visually-hidden">skip to content</a>

    <header class="masthead wayfinding">
      <a href="/" class="wordmark">datumwise</a>
      <nav aria-label="Primary">
        {nav.map((n) => (
          <a href={n.href} {...(n.external ? { rel: 'noopener', target: '_blank' } : {})}>{n.label}</a>
        ))}
      </nav>
    </header>

    <main id="main" class={wide ? 'flow-wide' : 'flow'}>
      <slot />
    </main>

    <footer class="footer wayfinding">
      <div class="footer-grid">
        <p class="foot-left">
          Columna is open source, Apache-2.0. The discipline needs no product — declare your anchors,
          name your populations, refuse out loud what your data cannot answer. Columna is our proof
          it can be made executable.
        </p>
        <p class="foot-center">
          <a href="https://doi.org/10.5281/zenodo.20762839" rel="noopener" target="_blank">The Silent Failure Atlas</a> (DOI 10.5281/zenodo.20762839) ·
          <a href="https://doi.org/10.5281/zenodo.20710717" rel="noopener" target="_blank">The Silent Seam</a> (DOI 10.5281/zenodo.20710717) ·
          <a href="https://doi.org/10.5281/zenodo.20789318" rel="noopener" target="_blank">The Two Anchors of a Measure</a> (DOI 10.5281/zenodo.20789318)
        </p>
        <p class="foot-right"><a href="/about">datumwise builds and stewards Columna.</a></p>
      </div>
      <p class="foot-disambig">
        Not <a href="https://columnar.tech" rel="noopener" target="_blank">Columnar</a> (columnar.tech), the Arrow-native fast pipe one letter away. They move columns fast; we govern what columns say. <a href="/ladder#the-fast-pipe">More →</a>
      </p>
      <hr class="rule rule-strong" />
      <p class="integrity mono">
        Every transcript and every number on this page is generated at build time by running the
        shipped package. This site is structurally incapable of demoing something it did not ship.
      </p>
      <p class="foot-meta">© {year} datumwise · <a href="/how-these-documents-relate">Research</a> · <a href="/how-these-documents-relate">How these documents relate</a> · <a href="/about">About</a></p>
    </footer>

    <AmbientChip />

    <style>
      .skip:focus { position: fixed; top: 0.5rem; left: 0.5rem; width: auto; height: auto; clip: auto;
        background: var(--ink); color: var(--paper); padding: 0.5rem 0.9rem; z-index: 100; }

      .masthead {
        display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
        width: min(100% - 3rem, 68rem); margin-inline: auto; padding: 1.5rem 0 1.25rem;
      }
      .wordmark { font-weight: 600; font-size: 1.05rem; letter-spacing: -0.02em; text-decoration: none; }
      .masthead nav { display: flex; gap: 1.4rem; font-size: 0.9rem; }
      .masthead nav a { color: var(--ink-soft); text-decoration: none; }
      .masthead nav a:hover { color: var(--ink); }

      .flow { width: min(100% - 3rem, var(--measure)); margin-inline: auto; }
      .flow-wide { width: 100%; }

      .footer { width: min(100% - 3rem, 68rem); margin: 5rem auto 3rem; font-size: 0.85rem; color: var(--ink-soft); }
      .footer-grid { display: grid; grid-template-columns: 1.4fr 1.6fr 0.8fr; gap: 2rem; align-items: start; }
      .foot-left { margin: 0; max-width: 26rem; }
      .foot-center { margin: 0; font-size: 0.78rem; line-height: 1.7; }
      .foot-center a { color: var(--ink-soft); }
      .foot-right { margin: 0; text-align: right; font-size: 0.8rem; color: var(--ink-faint); }
      .integrity { font-size: 0.78rem; color: var(--ink-soft); line-height: 1.6; max-width: 48rem; }
      .foot-meta { font-size: 0.75rem; color: var(--ink-faint); margin-top: 1.5rem; }
      .foot-meta a { color: var(--ink-faint); }

      @media (max-width: 46rem) {
        .footer-grid { grid-template-columns: 1fr; gap: 1.2rem; }
        .foot-right { text-align: left; }
        .masthead nav { gap: 1rem; font-size: 0.82rem; }
      }
    </style>
  </body>
</html>
