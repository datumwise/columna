---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content as Essay } from '../content/corpus/metadata_independence_essay_v0_2.md';
import { Content as Seam } from '../content/corpus/silent_seam_companion_v1_0.md';
---
<BaseLayout title="Why — datumwise">
  <div class="page-head">
    <p class="kicker">Why</p>
  </div>
  <article class="prose">
    <Essay />
    <hr />
    <p class="seam-note">The Silent Seam below was published against the Atlas's v1.0 count of sixty-six modes; the Atlas has since added one — the sixty-seven cited elsewhere on this site.</p>
    <Seam />
  </article>
  <p class="further-reading">Further reading: how this positions against semantic layers, modeling languages, and text-to-SQL — <a href="/ladder">The Ladder</a>.</p>
</BaseLayout>

<style>
  .further-reading { width: min(100% - 3rem, 46rem); margin: 2rem auto 0; font-size: 0.92rem; color: var(--ink-soft, #555); }
  /* editorial reconciliation note (the site's voice) — the reproduced Seam essay is byte-identical */
  .seam-note { width: min(100% - 3rem, 46rem); margin: 0 auto 1.5rem; font-size: 0.86rem; font-style: italic; color: var(--ink-soft, #666); }
</style>
