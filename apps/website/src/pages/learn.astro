---
// CP-3b Tier-2 — /learn. The gathered deep-dive surface (routing, not a glossary): the front door,
// the three manuals, the live Explorer, install, and the release. Release notes link the GitHub
// Release directly — no site page (package §2b, ratified).
import BaseLayout from '../layouts/BaseLayout.astro';

const RELEASE_URL = 'https://github.com/datumwise/columna/releases/tag/v0.9.0';

const groups = [
  {
    heading: 'Start here',
    items: [
      // The three What-is pieces, in build order (PROPOSED, Huayin's gate): Columna (the framework
      // orientation) → FrameQL (the language) → Manifold (the hub/synthesis, whose prose is written to
      // be read after both siblings). Alternative on offer: hub-first (Manifold leads).
      { href: '/what-is-columna', title: 'What is Columna?', blurb: 'A plain-language orientation — the pieces, by analogy, and the four moods an answer arrives in.' },
      { href: '/what-is-frameql', title: 'What is FrameQL — and why?', blurb: 'The query language in plain language — the Frame is the query, the three-part column, and where SQL and FrameQL part ways.' },
      { href: '/what-is-manifold', title: 'What is a Manifold?', blurb: 'The hub of the set — the new data model: substance where relational was form, and why its claims stand trial.' },
      { href: '/why-columna-looks-this-way', title: 'Why Columna looks the way it does', blurb: 'Where the structure came from — mostly not designed but written down, and why the taste-versus-no-choice lens changes how you evaluate it.' },
      { href: '/explorer', title: 'The Explorer', blurb: 'The demo Manifold, live — every measure, universe, and edge with its law, its verdict, and a query to try.' },
      { href: '/install', title: 'Install', blurb: 'Run it in two minutes — a clarify, a refuse, and a disclose print on your machine as real wire JSON.' },
    ],
  },
  {
    heading: 'The manuals',
    items: [
      { href: '/docs/framework', title: 'The framework manual (6e)', blurb: 'The full discipline, precisely — the Column-Operator-Frame substrate beneath the tools.' },
      { href: '/docs/frameql', title: 'The FrameQL manual (v1)', blurb: 'The query language against the Manifold, completely.' },
      { href: '/docs/reference', title: 'The reference manual (5e)', blurb: 'A distinct manual — the object model, the definition language, the Certificate layer.' },
    ],
  },
  {
    heading: 'Around the corpus',
    items: [
      { href: '/how-these-documents-relate', title: 'How these documents relate', blurb: 'The corpus map — how the thesis, the essays, the papers, and the manuals fit together.' },
      { href: RELEASE_URL, title: 'Release 0.9.0', blurb: 'The GitHub Release — the envelope becomes the language — what shipped, on PyPI.', external: true },
    ],
  },
];
---
<BaseLayout title="Learn — datumwise"
  description="Learn Columna — the front-door orientation, the three manuals, the live Explorer, install, and the release, gathered in one place.">
  <div class="page-head">
    <p class="kicker">Learn</p>
    <h1 class="serif">Learn Columna</h1>
    <p class="lede">One place that gathers the orientation, the three manuals, the live Explorer, and how to run it.
      New to the vocabulary? Start with <a href="/what-is-columna">What is Columna?</a></p>
  </div>

  {groups.map((g) => (
    <section class="learn-group">
      <h2 class="serif">{g.heading}</h2>
      <ul class="learn-list">
        {g.items.map((it) => (
          <li>
            <a href={it.href} {...(it.external ? { rel: 'noopener', target: '_blank' } : {})}>{it.title}{it.external ? ' ↗' : ''}</a>
            <span class="blurb">{it.blurb}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .page-head { width: min(100% - 3rem, 46rem); margin: 0 auto; }
  .page-head h1 { font-size: clamp(1.9rem, 4vw, 2.6rem); margin: 0.3rem 0 0.8rem; }
  .lede { font-size: 1.05rem; color: var(--ink-soft); max-width: 38rem; }
  .learn-group { width: min(100% - 3rem, 46rem); margin: 2.6rem auto 0; }
  .learn-group h2 { font-size: 1.25rem; margin: 0 0 0.9rem;
    border-bottom: 1px solid var(--rule); padding-bottom: 0.4rem; }
  .learn-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.1rem; }
  .learn-list li { display: grid; gap: 0.2rem; }
  .learn-list a { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; color: var(--ink);
    text-decoration: underline; text-decoration-color: var(--rule-strong); width: fit-content; }
  .learn-list a:hover { text-decoration-color: var(--ink-faint); }
  .blurb { font-size: 0.92rem; color: var(--ink-soft); }
</style>
