---
// The Case — Cascadia Retail, the case demo. The three chapters render VERBATIM (byte-identical copies
// of the ratified charter); the generated exhibits (trial table, four-mood wheel, the fourteen tables,
// the two artifacts, Figure 1) are GENERATED from the shipped package (scripts/gen_case.py ->
// src/data/case.generated.json), never hand-written.
//
// PRESENTATION RESTRUCTURE (Huayin, pre-launch): the reader-discipline law governs PAGE ASSEMBLY — one
// introduction total, every exhibit seated where the reader has earned it. Each chapter is split at its
// `## ` headings (render-time only — the .md bytes are untouched, so the three-surface byte-identical
// re-sync holds) and each generated exhibit mounts right AFTER the heading whose prose introduces it.
import BaseLayout from '../layouts/BaseLayout.astro';
import { marked } from 'marked';
import ch1raw from '../content/case/ch1.md?raw';
import ch2raw from '../content/case/ch2.md?raw';
import ch3raw from '../content/case/ch3.md?raw';
import caseData from '../data/case.generated.json';
import UniverseVisual from '../components/UniverseVisual.astro';

const verdictClass = (v) => ({
  corroborated: 'v-corroborated', verified: 'v-verified',
  untestable: 'v-untestable', recorded: 'v-recorded', contradicted: 'v-contradicted',
}[v] || 'v-recorded');

const moodClass = (m) => `mood-${m}`;
const wheel = caseData.wheel.map((id) => caseData.exemplars.find((e) => e.id === id));

// Split a chapter's RAW markdown into sections at `## ` boundaries (the file bytes are never mutated —
// this is a render-time cut, so the verbatim/byte-identical charter guarantee is preserved). The lead
// segment (title + intro, before the first `##`) carries heading = null.
function sections(raw) {
  return raw.split(/\n(?=## )/).map((part) => {
    const m = part.match(/^##\s+(.+?)\s*$/m);
    return { heading: m ? m[1].trim() : null, html: marked.parse(part) };
  });
}
const ch1Sections = sections(ch1raw);
const ch2Sections = sections(ch2raw);
const ch3Sections = sections(ch3raw);
---
<BaseLayout title="The Case — Cascadia Retail — datumwise"
  description="Cascadia Retail: a realistic case demo of Columna — the company, the data, the ask, the design and its reasons, and the system live. Every number is recorded from the shipped package, never illustrated.">
  <article class="prose case">
    <p class="case-lede">Cascadia Retail is a fictional 24-store chain with an ordinary warehouse and two
      famous bad numbers. This case walks the whole arc — the company, the data, the ask, the design and
      its reasons, and the system live — and every number in it is recorded, never illustrated.</p>
    <nav class="chapter-nav" aria-label="Chapters">
      <a href="#ch1">Company &amp; data</a>
      <a href="#ch2">The design</a>
      <a href="#ch3">Live</a>
    </nav>

    <!-- Chapter 1 — the setup; the fourteen tables mount where the data is met -->
    <section class="chapter" id="ch1">
      {ch1Sections.map((s) => (
        <>
          <Fragment set:html={s.html} />
          {s.heading === 'The data they have' && (
            <div class="exhibit-inline" aria-label="The warehouse tables">
              <p class="ex-cap"><span class="tag">generated</span> Fourteen tables, straight from the bundled
                warehouse — the six that drive the story expanded, the rest in full (note
                <code>daily_revenue_summary</code>'s <strong>716</strong> rows against the calendar's 731):</p>
              <div class="tables">
                {caseData.ch1_tables.filter((t) => t.prominent).map((t) => (
                  <details class="tbl" open={t.table === 'transactions'}>
                    <summary><code>{t.table}</code> <span class="rc">{t.row_count.toLocaleString()} rows</span></summary>
                    <div class="tbl-scroll">
                      <table class="rows">
                        <thead><tr>{t.columns.map((c) => <th>{c}</th>)}</tr></thead>
                        <tbody>{t.sample.map((r) => <tr>{r.map((v) => <td>{v}</td>)}</tr>)}</tbody>
                      </table>
                    </div>
                  </details>
                ))}
              </div>
              <p class="more-tables">The other eight — references and the stale summaries the model won't use:</p>
              <div class="tables">
                {caseData.ch1_tables.filter((t) => !t.prominent).map((t) => (
                  <details class="tbl compact">
                    <summary><code>{t.table}</code> <span class="rc">{t.row_count.toLocaleString()} rows</span>
                      <span class="cols-hint">{t.columns.join(', ')}</span></summary>
                    <div class="tbl-scroll">
                      <table class="rows">
                        <thead><tr>{t.columns.map((c) => <th>{c}</th>)}</tr></thead>
                        <tbody>{t.sample.map((r) => <tr>{r.map((v) => <td>{v}</td>)}</tr>)}</tbody>
                      </table>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}
        </>
      ))}
    </section>

    <hr />

    <!-- Chapter 2 — the two artifacts mount where the design is derived -->
    <section class="chapter" id="ch2">
      {ch2Sections.map((s) => (
        <>
          <Fragment set:html={s.html} />
          {s.heading === 'The design' && (
            <div class="exhibit-inline" aria-label="The two artifacts">
              <p class="ex-cap"><span class="tag">generated</span> One authored graph, two projections — the
                logical <strong>Manifold spec</strong> everyone reads, and the many-to-one
                <strong>physical→logical map</strong> with its rejects kept.
                {caseData.ch2_artifacts.wall_holds && <span class="wall">✓ the wall holds</span>}</p>
              <div class="artifacts">
                <div class="artifact logical">
                  <h3>The Manifold spec <span class="sub">logical — what everyone reads</span></h3>
                  <ul class="spec">
                    {caseData.ch2_artifacts.logical_spec.measures.map((m) => (
                      <li><code>{m.name}</code> <span class="desc">{m.description}</span></li>
                    ))}
                    {caseData.ch2_artifacts.logical_spec.derived.map((dv) => (
                      <li><code>{dv.name}</code> <span class="desc">= {dv.formula}</span></li>
                    ))}
                  </ul>
                </div>
                <div class="artifact physical">
                  <h3>The physical→logical map <span class="sub">many-to-one — the plumbing</span></h3>
                  <table class="map">
                    <thead><tr><th>logical</th><th>binds to</th><th>rejected (why)</th></tr></thead>
                    <tbody>
                      {caseData.ch2_artifacts.physical_map.filter((r) => r.binds_to !== '—').map((r) => (
                        <tr>
                          <td><code>{r.logical}</code></td>
                          <td><code class="phys">{r.binds_to}</code></td>
                          <td class="rej">{r.rejects.map((rj) => <div><code>{rj[0]}</code> <em>{rj[1]}</em></div>)}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          )}
        </>
      ))}
    </section>

    <hr />

    <!-- Chapter 3 — the Manifold live. build -> inspect -> use: the prose carries the trial table; the
         Explorer (Figure 1 + a pointer) seats between trials and outcomes; the four-mood wheel is the payoff. -->
    <section class="chapter" id="ch3">
      {ch3Sections.map((s) => (
        <>
          <Fragment set:html={s.html} />
          {s.heading === 'The Explorer' && (
            <div class="explorer-inline" aria-label="The Manifold, browsable">
              <UniverseVisual />
              <p class="pointer">Browse the whole Manifold live — every declaration with its law, its
                verdict, and a query to try — at <a href="/explorer">/explorer</a>.</p>
            </div>
          )}
          {s.heading && s.heading.startsWith('The questions, asked') && (
            <div class="exhibit-inline" aria-label="The four moods">
              <p class="ex-cap"><span class="tag">generated</span> The same asks the packaged
                <code>demo --play</code> runs, in story order — each a real wire outcome:</p>
              <div class="wheel">
                {wheel.map((e) => (
                  <div class={`mood-card ${moodClass(e.mood)}`}>
                    <div class="mood-head"><span class="mood-name">{e.mood}</span>
                      {e.reason_tokens.length > 0 && <span class="mood-reason">{e.reason_tokens.join(', ')}</span>}</div>
                    <code class="mood-q">{e.query}</code>
                    <p class="mood-cap">{e.caption}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
        </>
      ))}
    </section>
  </article>

  <style>
    .case .lede { font-size: 1.05rem; color: var(--ink-soft); }
    /* the case study lede (informational register) + chapter nav — the page's only intro */
    .case .case-lede { font-size: 1.08rem; line-height: 1.55; color: var(--ink); margin-top: 0.2rem; }
    .case .chapter-nav { display: flex; flex-wrap: wrap; gap: 0.5rem 1.1rem; margin: 0.9rem 0 1.4rem;
      font-size: 0.9rem; }
    .case .chapter-nav a { color: var(--ink-soft); text-decoration: none; border-bottom: 1px solid var(--rule, #e5e2dc);
      padding-bottom: 1px; }
    .case .chapter-nav a:hover { color: var(--ink); border-bottom-color: currentColor; }

    /* an exhibit seated INSIDE a chapter's flow — lighter than a standalone card, so it reads as the
       recorded evidence for the prose just above it, not a competing section */
    .exhibit-inline { margin: 1rem 0 1.6rem; }
    .ex-cap { font-size: 0.9rem; color: var(--ink-soft); margin: 0.2rem 0 0.7rem; }
    .tag { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; vertical-align: middle;
      background: #eceae4; color: #6b675f; border-radius: 4px; padding: 0.1rem 0.4rem; margin-right: 0.4rem; }

    .verdict { font-weight: 600; font-size: 0.82rem; padding: 0.1rem 0.5rem; border-radius: 999px; white-space: nowrap; }
    .v-corroborated { background: #e6f2e6; color: #2f6b34; }
    .v-verified { background: #e4eefb; color: #2456a6; }
    .v-untestable { background: #f2efe6; color: #7a6f4e; }
    .v-recorded { background: #efeced; color: #6a5f66; }
    .v-contradicted { background: #fbe6e6; color: #a63030; }

    .wheel { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.8rem; }
    .mood-card { border: 1px solid #e5e2dc; border-left: 4px solid #b9b4a9; border-radius: 8px; padding: 0.7rem 0.8rem; background: #fff; }
    .mood-serve { border-left-color: #2f6b34; }
    .mood-disclose { border-left-color: #c08a1e; }
    .mood-clarify { border-left-color: #2456a6; }
    .mood-refuse { border-left-color: #a63030; }
    .mood-head { display: flex; justify-content: space-between; align-items: baseline; gap: 0.4rem; }
    .mood-name { font-weight: 700; text-transform: uppercase; font-size: 0.78rem; letter-spacing: 0.06em; }
    .mood-reason { font-size: 0.68rem; color: #8a8478; font-family: ui-monospace, monospace; }
    .mood-q { display: block; font-size: 0.8rem; margin: 0.35rem 0; word-break: break-word; }
    .mood-cap { font-size: 0.85rem; color: var(--ink-soft); margin: 0.2rem 0 0; }

    /* the Explorer pointer — Figure 1 inline + the route (seated between trials and outcomes) */
    .explorer-inline { margin: 1rem 0 1.6rem; }
    .explorer-inline .pointer { font-size: 0.92rem; color: var(--ink-soft); margin: 0.6rem 0 0; }

    /* ch1 schema-and-rows */
    .tables { display: grid; gap: 0.5rem; }
    .tbl { border: 1px solid #e5e2dc; border-radius: 8px; background: #fff; }
    .tbl summary { cursor: pointer; padding: 0.5rem 0.7rem; font-family: ui-monospace, monospace; font-size: 0.85rem; }
    .tbl .rc { color: #8a8478; font-size: 0.78rem; margin-left: 0.4rem; }
    .tbl-scroll { overflow-x: auto; }
    table.rows { border-collapse: collapse; font-size: 0.72rem; font-family: ui-monospace, monospace; width: 100%; }
    table.rows th, table.rows td { border: 1px solid #eee; padding: 0.25rem 0.45rem; white-space: nowrap; text-align: left; }
    table.rows th { background: #f6f4ef; color: #6b675f; font-weight: 600; }
    .more-tables { font-size: 0.85rem; color: var(--ink-soft); margin: 0.9rem 0 0.4rem; }
    .tbl.compact summary { font-size: 0.8rem; color: #6b675f; }
    .tbl.compact .cols-hint { display: block; font-family: ui-monospace, monospace; font-size: 0.68rem;
      color: #a49e91; margin-top: 0.15rem; white-space: normal; }

    /* ch2 two artifacts */
    .wall { font-size: 0.72rem; color: #2f6b34; margin-left: 0.5rem; }
    .artifacts { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 760px) { .artifacts { grid-template-columns: 1fr; } }
    .artifact { border: 1px solid #e5e2dc; border-radius: 8px; padding: 0.7rem 0.9rem; background: #fff; }
    .artifact.logical { border-left: 4px solid #2456a6; }
    .artifact.physical { border-left: 4px solid #8a8478; }
    .artifact h3 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .artifact .sub { display: block; font-weight: 400; font-size: 0.72rem; color: #8a8478; text-transform: none; }
    ul.spec { list-style: none; margin: 0; padding: 0; }
    ul.spec li { padding: 0.25rem 0; border-bottom: 1px solid #f1efe9; font-size: 0.82rem; }
    ul.spec .desc { color: var(--ink-soft); }
    table.map { border-collapse: collapse; width: 100%; font-size: 0.76rem; }
    table.map th, table.map td { text-align: left; padding: 0.3rem 0.4rem; border-bottom: 1px solid #f1efe9; vertical-align: top; }
    table.map th { color: #6b675f; }
    .phys { color: #7a6f4e; }
    .rej { font-size: 0.72rem; color: #8a8478; }
    .rej em { color: #a07a55; font-style: normal; }
  </style>
</BaseLayout>
