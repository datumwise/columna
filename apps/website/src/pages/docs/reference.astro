---
// CP-3b Tier-2 — /docs/reference. Renders the Columna reference manual (5e) from the repo-root docs/
// residency as-is. The 5e disposition (package §3): ROUTED and labeled unambiguously as a DISTINCT
// manual — the object model, the definition language, the Certificate layer — NOT a stale edition of
// the framework manual. Rides the CP-M2 gate + ONE-DEPLOY discipline; built now so it renders.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Content } from '../../../../../docs/columna_reference_manual_5e.md';
---
<BaseLayout title="The Columna reference manual — datumwise"
  description="The Columna reference manual (5th ed.) — the object model, the definition language, the Certificate layer.">
  <div class="page-head">
    <p class="kicker"><a href="/learn">Learn</a> · Manual</p>
