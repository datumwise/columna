      A distinct manual from the framework manual (6e) and the FrameQL manual (v1).</p>
  </div>
  <article class="prose">
    <Content />
  </article>
</BaseLayout>

<style>
  .page-head { width: min(100% - 3rem, var(--measure)); margin: 0 auto 1.5rem; }
  .kicker a { color: var(--ink-soft); }
  .ref-note { font-size: 0.9rem; color: var(--ink-soft); margin: 0.6rem 0 0; }
</style>
