---
// Exhibit B — the argument, executed. Renders REAL wire JSON (the JSON is the exhibit).
//
// Data source: the CI-generated transcript (every payload produced by the shipped package). The
// widget attempts the live endpoint first and asserts contract_version=="1"; on failure/timeout/429
// it degrades to this recorded transcript, clearly stamped. (Live MCP wiring activates once the Fly
// endpoint is approved + deployed; until then the degrade path — itself a first-class requirement —
// is what shows, and it is 100% real shipped-package wire.)
//
// The clarify round-trip mirrors `demo --play` exactly (WP-2.2 two-hop contract, worklist item 5 —
// unrealizable alternatives): clarify → pick a population → refuse (the other operand is out of that
// universe) → the honest resolution is separate columns → disclose.
import transcript from '../data/transcript.generated.json';
import seeded from '../data/seeded_queries.json';
import wireStrings from '../data/wire_strings.json';

const labels = Object.fromEntries(seeded.queries.map((q: any) => [q.id, q.label]));
// key the round-trip by universe for easy lookup
const rt: Record<string, any> = {};
for (const [, v] of Object.entries<any>(transcript.clarify_roundtrip)) {
  rt[v.apply.universe] = v.wire;
}
const data = {
  meta: transcript.meta,
  seeded: {
    clarify: { label: labels.clarify, wire: transcript.seeded.clarify.wire },
    disclose: { label: labels.disclose, wire: transcript.seeded.disclose.wire },
    refuse: { label: labels.refuse, wire: transcript.seeded.refuse.wire },
    serve: { label: labels.serve, wire: transcript.seeded.serve.wire },
  },
  roundtrip: rt,
  foolIt: {
    wire: transcript.fool_it.wire,
    measureIndex: transcript.fool_it.measure_index,
    placeholder: seeded.foolIt.placeholder,
    template: seeded.foolIt.template,
  },
  endpoint: seeded.endpoint,
  // Manifold Explorer (tier 1): captured describe wire + the governed communicative strings
  describe: transcript.describe,
  strings: wireStrings,
};
const genDate = new Date(transcript.meta.generated_at).toISOString().slice(0, 10);
---
<section class="exhibit-b" id="exhibit-b" aria-label="Exhibit B: the argument, executed">
  <p class="wire-caption mono">this is the actual wire — what an AI agent receives. Every answer is a pair: a result, and its disclosure. The mood is how the pair reads.</p>

  <details class="manifold-panel">
    <summary>what's in this manifold? <span class="mf-hint">— explore the data before you ask</span></summary>
    <div class="mf-body" data-manifold-panel></div>
    <p class="mf-explorer-link"><a href="/explorer">Browse the whole Manifold → the Explorer</a></p>
  </details>

  <div class="explorer-slot" data-explorer-slot hidden></div>

  <p class="seed-prompt">👇 <strong>Tap a question to run it live.</strong> You'll get back the real result <em>and</em> the mood it answers in — served, disclosed, clarified, or refused.</p>

  <div class="seed-row" role="group" aria-label="Ask the system — tap a question to run it">
    <button type="button" data-seed="clarify">{data.seeded.clarify.label}</button>
    <button type="button" data-seed="disclose">{data.seeded.disclose.label}</button>
    <button type="button" data-seed="refuse">{data.seeded.refuse.label}</button>
    <button type="button" data-seed="serve">{data.seeded.serve.label}</button>
  </div>

  <div class="response" data-response aria-live="polite"></div>

  <form class="fool-it" data-fool>
    <label for="fool-input" class="fool-label mono">try to fool it — ask for a measure by name</label>
    <div class="fool-row">
      <input id="fool-input" type="text" autocomplete="off" spellcheck="false" placeholder={data.foolIt.placeholder} />
      <button type="submit">ask</button>
    </div>
    <p class="fool-hint">this exact refusal, captured live, ships in the package.</p>
  </form>

  <p class="degrade-note mono" data-degrade hidden>
    live demo temporarily offline — this transcript was generated from the shipped package at build time ({genDate}).
  </p>

  <script type="application/json" data-exhibit-b set:html={JSON.stringify(data)}></script>
</section>

<style>
  .exhibit-b { font-family: var(--font-sans); margin: 2rem 0; border: 1px solid var(--wire-rule);
    border-radius: 10px; background: var(--wire-bg); color: var(--wire-ink); padding: 1.5rem 1.6rem; }
  .wire-caption { font-size: 0.8rem; color: var(--wire-ink-soft); line-height: 1.6; margin: 0 0 1.3rem; }

  .seed-prompt { font-size: 0.9rem; line-height: 1.55; color: var(--wire-ink); margin: 0 0 1rem;
    border-left: 2px solid var(--mood-clarify); padding-left: 0.8rem; }
  .seed-prompt strong { color: #fff; }

  .seed-row { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-bottom: 1.3rem; }
  .seed-row button { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--font-sans);
    font-size: 0.84rem; text-align: left; padding: 0.55rem 0.9rem 0.55rem 0.75rem;
    background: #1b2432; border: 1px solid #34425a; border-radius: 8px; color: var(--wire-ink);
    cursor: pointer; transition: background .12s, border-color .12s, transform .05s; }
  .seed-row button::before { content: "▸"; color: var(--mood-clarify); font-size: 0.8rem; flex: none; }
  .seed-row button:hover { background: #223047; border-color: var(--wire-key); }
  .seed-row button:active { transform: translateY(1px); }
  .seed-row button[aria-pressed="true"] { border-color: var(--wire-key); background: #26364f; box-shadow: inset 0 0 0 1px var(--wire-key); }
  .seed-row button[aria-pressed="true"]::before { content: "\2713"; color: var(--mood-serve); }

  .response { display: grid; gap: 1rem; }

  .fool-it { margin-top: 1.5rem; padding-top: 1.3rem; border-top: 1px solid var(--wire-rule); }
  .fool-label { display: block; font-size: 0.78rem; color: var(--wire-ink-soft); margin-bottom: 0.5rem; }
  .fool-row { display: flex; gap: 0.5rem; }
  .fool-row input { flex: 1; font-family: var(--font-mono); font-size: 0.85rem; padding: 0.5rem 0.7rem;
    background: var(--wire-bg); border: 1px solid var(--wire-rule); border-radius: 6px; color: var(--wire-ink); }
  .fool-row input:focus { outline: none; border-color: var(--wire-ink-soft); }
  .fool-row button { font-family: var(--font-sans); font-weight: 600; font-size: 0.82rem; padding: 0 1.15rem;
    background: var(--mood-clarify); border: 1px solid var(--mood-clarify); border-radius: 6px; color: #fff;
    cursor: pointer; transition: filter .12s; }
  .fool-row button:hover { filter: brightness(1.12); }
  .fool-row button:disabled { opacity: 0.55; cursor: default; }
  .fool-hint { font-size: 0.76rem; color: var(--wire-ink-soft); margin: 0.5rem 0 0; }

  .degrade-note { margin: 1.2rem 0 0; font-size: 0.74rem; color: var(--mood-disclose); }

  @media (max-width: 40rem) { .seed-row button { font-size: 0.78rem; } }
</style>

<!-- Card internals are rendered by client JS (exhibit-b.ts) and never get Astro's scoped-style
     attribute, so these MUST be global. Namespaced under .exhibit-b to avoid leaking. -->
<style is:global>
  .exhibit-b .resp-card { border: 1px solid var(--wire-rule); border-radius: 8px; padding: 1.15rem 1.25rem; background: var(--wire-panel); }

  .exhibit-b .mood-badge { display: inline-block; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700;
    padding: 0.2rem 0.7rem; border-radius: 999px; color: #fff; letter-spacing: 0.03em; text-transform: uppercase; }
  .exhibit-b .mood-serve { background: var(--mood-serve); }
  .exhibit-b .mood-disclose { background: var(--mood-disclose); }
  .exhibit-b .mood-clarify { background: var(--mood-clarify); }
  .exhibit-b .mood-refuse { background: var(--mood-refuse); }
  .exhibit-b .mood-error { background: transparent; color: var(--mood-error); border: 1px solid var(--mood-error); text-transform: none; }

  .exhibit-b .resp-heading { font-size: 0.86rem; color: var(--wire-ink-soft); line-height: 1.5; margin-bottom: 0.8rem; }

  .exhibit-b .resp-head { display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.6rem 0.8rem;
    padding-bottom: 0.9rem; border-bottom: 1px solid var(--wire-rule); }
  .exhibit-b .resp-summary { font-size: 0.95rem; margin: 0; color: var(--wire-ink); line-height: 1.5; flex: 1 1 14rem; }

  .exhibit-b .vlabel { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--wire-ink-soft); margin: 1rem 0 0.5rem; }

  .exhibit-b .resp-values { margin-top: 0.2rem; overflow-x: auto; }
  .exhibit-b .wire-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 0.82rem; }
  .exhibit-b .wire-table th { text-align: left; font-weight: 600; color: var(--wire-key); padding: 0.35rem 0.9rem 0.35rem 0;
    border-bottom: 1px solid var(--wire-ink-soft); white-space: nowrap; }
  .exhibit-b .wire-table td { padding: 0.32rem 0.9rem 0.32rem 0; border-bottom: 1px solid var(--wire-rule); color: var(--wire-ink); white-space: nowrap; }
  .exhibit-b .wire-table th:last-child, .exhibit-b .wire-table td:last-child { padding-right: 0; }
  .exhibit-b .wire-table tbody tr:last-child td { border-bottom: 0; }
  .exhibit-b .wire-table tbody tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
  .exhibit-b .wire-table th.num, .exhibit-b .wire-table td.num { text-align: right; font-variant-numeric: tabular-nums; padding-left: 1.6rem; }
  .exhibit-b .wire-table td.num { color: #fff; }
  .exhibit-b .wire-table .nil { color: var(--wire-ink-soft); }

  .exhibit-b .resp-index { margin-top: 0.2rem; }
  .exhibit-b .index-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .exhibit-b .index-tags .tag { font-family: var(--font-mono); font-size: 0.78rem; padding: 0.2rem 0.55rem;
    background: #1b2432; border: 1px solid var(--wire-rule); border-radius: 5px; color: var(--wire-ink); }

  .exhibit-b .disc-section { margin-top: 0.3rem; }
  .exhibit-b .disc { margin-top: 0.6rem; border-left: 2px solid; padding: 0.4rem 0 0.4rem 0.8rem; font-size: 0.86rem; color: var(--wire-ink); line-height: 1.5; }
  .exhibit-b .disc-info { border-color: var(--mood-clarify); }
  .exhibit-b .disc-caution { border-color: var(--mood-disclose); }
  .exhibit-b .disc-critical { border-color: var(--mood-refuse); }
  .exhibit-b .disc-code { font-family: var(--font-mono); font-size: 0.74rem; color: var(--wire-ink-soft); display: block; margin-bottom: 0.2rem; }

  .exhibit-b .alts { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.4rem; }
  .exhibit-b .alts button, .exhibit-b .resolve-btn { font-family: var(--font-mono); font-size: 0.8rem; padding: 0.45rem 0.8rem;
    background: #1b2432; border: 1px solid #34425a; border-radius: 6px; color: var(--wire-ink); cursor: pointer;
    transition: background .12s, border-color .12s; }
  .exhibit-b .alts button:hover, .exhibit-b .resolve-btn:hover { background: #223047; border-color: var(--wire-key); }
  .exhibit-b .alts button[aria-pressed="true"] { border-color: var(--wire-key); box-shadow: inset 0 0 0 1px var(--wire-key); }
  .exhibit-b .resolve-btn { margin-top: 0.6rem; border-color: var(--mood-clarify); color: #fff; }
  .exhibit-b .pick-note { font-size: 0.85rem; color: var(--wire-ink-soft); margin: 0.6rem 0 0; font-style: italic; line-height: 1.5; }

  .exhibit-b .audit-toggle { margin-top: 0.9rem; font-family: var(--font-mono); font-size: 0.76rem; color: var(--wire-ink-soft);
    background: none; border: 0; cursor: pointer; text-decoration: underline; padding: 0; }
  .exhibit-b .audit-body { margin-top: 0.5rem; }

  .exhibit-b .wire-pane { margin-top: 0.9rem; }
  .exhibit-b .wire-pane summary { font-family: var(--font-mono); font-size: 0.74rem; color: var(--wire-ink-soft); cursor: pointer; }
  .exhibit-b .wire-pane pre { margin: 0.5rem 0 0; font-family: var(--font-mono); font-size: 0.74rem; line-height: 1.5;
    color: var(--wire-ink); background: var(--wire-bg); border: 1px solid var(--wire-rule); border-radius: 6px;
    padding: 0.8rem; overflow-x: auto; max-height: 22rem; }
  .exhibit-b .wire-pane .k { color: var(--wire-key); }
  .exhibit-b .wire-pane .s { color: var(--wire-string); }

  /* ---- Manifold Explorer (tier 1) ---- */
  .exhibit-b .manifold-panel { border: 1px solid var(--wire-rule); border-radius: 8px; background: var(--wire-panel);
    margin-bottom: 1.1rem; }
  .exhibit-b .manifold-panel > summary { cursor: pointer; padding: 0.7rem 0.9rem; font-family: var(--font-mono);
    font-size: 0.84rem; color: var(--wire-ink); list-style: none; }
  .exhibit-b .manifold-panel > summary::-webkit-details-marker { display: none; }
  .exhibit-b .manifold-panel > summary::before { content: "▸ "; color: var(--wire-key); }
  .exhibit-b .manifold-panel[open] > summary::before { content: "▾ "; }
  .exhibit-b .manifold-panel .mf-hint { color: var(--wire-ink-soft); }
  .exhibit-b .mf-body { padding: 0.2rem 0.9rem 1rem; display: grid; gap: 0.9rem; }
  .exhibit-b .mf-block { display: grid; gap: 0.4rem; }
  .exhibit-b .mf-uni { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.4rem 0.6rem; }
  .exhibit-b .mf-uni-desc { color: var(--wire-ink-soft); font-size: 0.82rem; }
  .exhibit-b .mf-deriv { font-family: var(--font-mono); font-size: 0.82rem; color: var(--wire-ink); padding: 0.1rem 0; }

  /* doorways — inline tap-targets into describe cards */
  .exhibit-b .door { font: inherit; font-family: var(--font-mono); background: none; border: 0; padding: 0;
    color: var(--wire-key); border-bottom: 1px dotted var(--wire-key); cursor: pointer; line-height: 1.2; }
  .exhibit-b .door:hover { color: #fff; border-bottom-color: #fff; }
  .exhibit-b .index-tags .door.tag { border: 1px solid var(--wire-rule); border-radius: 5px; padding: 0.2rem 0.55rem;
    color: var(--wire-ink); background: #1b2432; border-bottom: 1px solid var(--wire-rule); }
  .exhibit-b .index-tags .door.tag:hover { border-color: var(--wire-key); color: #fff; }

  /* glossary terms — dotted underline, tooltip on hover/focus/tap */
  .exhibit-b .gloss { border-bottom: 1px dashed var(--wire-ink-soft); cursor: help; }

  /* the shared describe-card slot + object cards */
  .exhibit-b .explorer-slot { margin: 0 0 1.1rem; }
  .exhibit-b .obj-card { border: 1px solid var(--wire-rule); border-left: 3px solid var(--wire-key);
    border-radius: 8px; background: #10151d; padding: 0.9rem 1rem; margin-top: 0.8rem; }
  .exhibit-b .obj-head { display: flex; align-items: center; gap: 0.5rem; font-size: 0.95rem; color: var(--wire-ink); }
  .exhibit-b .obj-kind { font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--wire-bg); background: var(--wire-key); padding: 0.12rem 0.45rem; border-radius: 4px; }
  .exhibit-b .obj-kind.metric { background: var(--mood-disclose); }
  .exhibit-b .obj-card .obj-meta code { color: var(--wire-ink); }
  .exhibit-b .obj-close { margin-left: auto; background: none; border: 0; color: var(--wire-ink-soft); cursor: pointer; font-size: 0.9rem; }
  .exhibit-b .obj-close:hover { color: #fff; }
  .exhibit-b .obj-note { font-size: 0.86rem; color: var(--wire-ink-soft); margin: 0.5rem 0 0; line-height: 1.5; }
  .exhibit-b .obj-meta { display: flex; flex-wrap: wrap; gap: 0.3rem 1.2rem; margin-top: 0.6rem;
    font-family: var(--font-mono); font-size: 0.8rem; color: var(--wire-ink); }
  .exhibit-b .obj-meta em { font-style: normal; color: var(--wire-ink-soft); margin-right: 0.35rem; }
  .exhibit-b .obj-meta code { color: var(--wire-string); }
  .exhibit-b .cone { margin-top: 0.7rem; padding-top: 0.7rem; border-top: 1px solid var(--wire-rule); }
  .exhibit-b .cone-h { font-family: var(--font-mono); font-size: 0.78rem; color: var(--wire-ink-soft); margin-bottom: 0.35rem; }
  .exhibit-b .grains { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .exhibit-b .grain { font-family: var(--font-mono); font-size: 0.76rem; padding: 0.12rem 0.45rem;
    background: #1b2432; border: 1px solid var(--wire-rule); border-radius: 4px; color: var(--wire-ink); }
  .exhibit-b .barred { margin-top: 0.4rem; font-size: 0.82rem; color: var(--wire-ink); line-height: 1.5; }
  .exhibit-b .barred-x { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--mood-refuse); border: 1px solid var(--mood-refuse); border-radius: 4px; padding: 0.05rem 0.35rem; margin-right: 0.35rem; }
  .exhibit-b .barred-why { color: var(--wire-ink-soft); }
  .exhibit-b .onepager-link { display: inline-block; margin-top: 0.7rem; font-family: var(--font-mono); font-size: 0.76rem; color: var(--wire-key); }

  /* engine-detail toggle (verbatim wire detail, one tap away) */
  .exhibit-b .engine-detail { margin-top: 0.4rem; }
  .exhibit-b .engine-detail summary { font-family: var(--font-mono); font-size: 0.72rem; color: var(--wire-ink-soft); cursor: pointer; }
  .exhibit-b .engine-detail-body { font-family: var(--font-mono); font-size: 0.76rem; color: var(--wire-ink-soft);
    margin-top: 0.3rem; padding-left: 0.6rem; border-left: 1px solid var(--wire-rule); line-height: 1.5; }

  /* the shared glossary tooltip lives on <body> (outside .exhibit-b) */
  .gloss-tip { position: absolute; z-index: 50; max-width: 20rem; font-family: var(--font-sans); font-size: 0.82rem;
    line-height: 1.5; color: var(--wire-ink); background: #23304a; border: 1px solid var(--wire-key);
    border-radius: 6px; padding: 0.6rem 0.75rem; box-shadow: 0 8px 28px rgba(0,0,0,0.55); pointer-events: auto; }
  .gloss-tip strong { color: #fff; }
  .gloss-tip a { color: var(--wire-key); margin-left: 0.3rem; }
</style>

<script>
  import '../scripts/exhibit-b.ts';
</script>
