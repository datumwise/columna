---
// CP-3b Tier-1 — the "Ask your AI" copy-block. A self-contained <details> whose body is a
// paste-into-any-chat prompt (definition + surrounding law + one example + the invitation) with a
// copy-to-clipboard button. The copied text is the block's plain text, verbatim (package §1c).
//
// `tone`: "paper" (default, the essay register) or "wire" (the dark terminal card in ExhibitB).
export interface Props {
  summary?: string;
  text: string;
  tone?: 'paper' | 'wire';
}
const { summary = 'Ask your AI about this', text, tone = 'paper' } = Astro.props;
---
<details class:list={['ask-ai', `ask-ai--${tone}`]}>
  <summary><span class="ask-ai-spark" aria-hidden="true">✦</span> {summary}</summary>
  <div class="ask-ai-body">
    <pre class="ask-ai-text" data-ask-text>{text}</pre>
    <button type="button" class="ask-ai-copy" data-ask-copy>Copy prompt</button>
  </div>
</details>

<style>
  .ask-ai { margin: 1rem 0; border-radius: 8px; font-family: var(--font-sans); }
  .ask-ai > summary { cursor: pointer; font-size: 0.85rem; padding: 0.5rem 0.75rem;
    list-style: none; display: flex; align-items: center; gap: 0.45rem; border-radius: 8px; }
  .ask-ai > summary::-webkit-details-marker { display: none; }
  .ask-ai-spark { font-size: 0.8em; opacity: 0.8; }
  .ask-ai-body { padding: 0.2rem 0.75rem 0.75rem; }
  .ask-ai-text { font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.6;
    white-space: pre-wrap; margin: 0.4rem 0 0.7rem; padding: 0.7rem 0.8rem; border-radius: 6px; }
  .ask-ai-copy { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600;
    padding: 0.35rem 0.85rem; border-radius: 6px; cursor: pointer; }
  .ask-ai-copy[data-copied="true"] { opacity: 0.75; }

  /* paper register — the essay pages */
  .ask-ai--paper { border: 1px solid var(--rule); background: var(--paper-raised); }
  .ask-ai--paper > summary { color: var(--ink-soft); }
  .ask-ai--paper > summary:hover { color: var(--ink); }
  .ask-ai--paper .ask-ai-text { background: var(--paper); color: var(--ink);
    border: 1px solid var(--rule); }
  .ask-ai--paper .ask-ai-copy { background: var(--ink); color: var(--paper); border: 1px solid var(--ink); }

  /* wire register — the dark terminal card (ExhibitB) */
  .ask-ai--wire { border: 1px solid var(--wire-rule); background: var(--wire-panel); }
  .ask-ai--wire > summary { color: var(--wire-ink-soft); }
  .ask-ai--wire > summary:hover { color: var(--wire-ink); }
  .ask-ai--wire .ask-ai-text { background: var(--wire-bg); color: var(--wire-ink);
    border: 1px solid var(--wire-rule); }
  .ask-ai--wire .ask-ai-copy { background: var(--wire-key); color: var(--wire-bg); border: 1px solid var(--wire-key); }
</style>

<script>
  // Delegated copy handler — one listener serves every AskYourAI on the page (Astro bundles this once).
  document.addEventListener('click', (ev) => {
    const btn = (ev.target as HTMLElement)?.closest?.('[data-ask-copy]') as HTMLButtonElement | null;
    if (!btn) return;
    const body = btn.closest('.ask-ai-body');
    const pre = body?.querySelector('[data-ask-text]') as HTMLElement | null;
    const text = pre?.innerText ?? '';
    const done = () => {
      const original = btn.textContent;
      btn.textContent = 'Copied ✓';
      btn.dataset.copied = 'true';
      window.setTimeout(() => {
        btn.textContent = original;
        delete btn.dataset.copied;
      }, 1600);
    };
    if (navigator.clipboard?.writeText) {
      navigator.clipboard.writeText(text).then(done).catch(() => fallbackCopy(text, done));
    } else {
      fallbackCopy(text, done);
    }
  });

  function fallbackCopy(text: string, done: () => void) {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch { /* no-op */ }
    document.body.removeChild(ta);
    done();
  }
</script>
