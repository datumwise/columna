{
  "endpoint": "https://demo-endpoint-vercel.vercel.app/query",
  "manifold": "benchmark",
  "contract_version": "1",
  "queries": [
    { "id": "clarify",  "label": "the average of aov, by month — averaged from which grain?", "frameql": "SELECT avg(aov) AT {cal.month}",        "universe": null, "intended": "clarify" },
    { "id": "refuse",   "label": "last inventory, by customer — but inventory has no customers", "frameql": "SELECT level.last AT {customer}",      "universe": null, "intended": "refuse" },
    { "id": "disclose", "label": "stock summed into months, per store",                  "frameql": "SELECT level.sum AT {store*cal.month}", "universe": null, "intended": "disclose" },
    { "id": "serve",    "label": "average order value (aov), by month",                  "frameql": "SELECT aov AT {cal.month}",             "universe": null, "intended": "serve" }
  ],
  "foolIt": { "placeholder": "profit_margin", "template": "SELECT %s AT {cal.month}" }
}
